{
  "name": "gdscript-reference-codelens",
  "displayName": "GDScript Reference CodeLens",
  "description": "Show reference counts above GDScript functions",
  "version": "0.0.1",
  "publisher": "cycreate",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuanotes/gdscript-reference-codelens.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:gdscript",
    "onLanguage:gd"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "GDScript Reference CodeLens",
      "properties": {
        "gdscriptReferenceCodeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable reference CodeLens for GDScript."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  }
}